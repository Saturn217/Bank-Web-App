{
    "version": 2,
    "builds": [
        {"src": "api/index.js", "use": "@vercel/node"}
    ],
    "routes": [
        {"src": "/(.*)", "dest": "api/index.js"}
    ],
    "crons": [
        {
            "path": "/api/v1/admin/trigger-interest?secret=@CRON_SECRET",
            "schedule": "0 0 1 * *"
        }
    ]
}