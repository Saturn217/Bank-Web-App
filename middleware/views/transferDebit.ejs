<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Debit Alert</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #f1f5f9; font-family: 'Segoe UI', Arial, sans-serif; color: #1e293b; }
    .wrapper { max-width: 580px; margin: 40px auto; background: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
    .header { background: linear-gradient(135deg, #1b3a6b 0%, #2563eb 100%); padding: 36px 40px 28px; text-align: center; }
    .header-logo { font-size: 1.1rem; font-weight: 700; color: rgba(255,255,255,0.7); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 6px; }
    .header-title { font-size: 1.5rem; font-weight: 700; color: white; }
    .amount-band { background: #fef2f2; border-bottom: 3px solid #ef4444; padding: 28px 40px; text-align: center; }
    .amount-label { font-size: 0.78rem; font-weight: 700; color: #ef4444; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
    .amount-value { font-size: 2.4rem; font-weight: 700; color: #ef4444; }
    .body { padding: 32px 40px; }
    .greeting { font-size: 1rem; font-weight: 600; color: #1b3a6b; margin-bottom: 10px; }
    .intro { font-size: 0.9rem; color: #64748b; line-height: 1.6; margin-bottom: 28px; }
    .detail-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; margin-bottom: 24px; }
    .detail-row { display: flex; justify-content: space-between; align-items: center; padding: 13px 18px; border-bottom: 1px solid #f1f5f9; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { font-size: 0.82rem; color: #64748b; }
    .detail-value { font-size: 0.88rem; font-weight: 600; color: #1e293b; text-align: right; }
    .detail-value.debit { color: #ef4444; font-size: 1rem; font-weight: 700; }
    .detail-value.balance { color: #1b3a6b; }
    .note-box { background: #fffbeb; border: 1px solid #fde68a; border-radius: 10px; padding: 14px 18px; margin-bottom: 24px; font-size: 0.85rem; color: #92400e; }
    .note-label { font-weight: 700; margin-bottom: 4px; }
    .alert-box { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 10px; padding: 14px 18px; margin-bottom: 28px; font-size: 0.84rem; color: #166534; line-height: 1.6; }
    .footer { background: #f8fafc; border-top: 1px solid #e2e8f0; padding: 24px 40px; text-align: center; }
    .footer-text { font-size: 0.78rem; color: #94a3b8; line-height: 1.7; }
    .footer-brand { font-size: 0.82rem; font-weight: 700; color: #1b3a6b; margin-bottom: 6px; }
    .tx-id { font-size: 0.72rem; color: #cbd5e1; margin-top: 8px; font-family: monospace; }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Header -->
    <div class="header">
      <div class="header-logo">Bank of Saturn</div>
      <div class="header-title">Debit Alert</div>
    </div>

    <!-- Amount band -->
    <div class="amount-band">
      <div class="amount-label">Amount Debited</div>
      <div class="amount-value">-₦<%= amount.toLocaleString('en-NG', { minimumFractionDigits: 2 }) %></div>
    </div>

    <!-- Body -->
    <div class="body">
      <div class="greeting">Hello, <%= fullName %>!</div>
      <div class="intro">
        Your Bank of Saturn account has been debited. Please find the transaction details below.
        If you did not authorise this transfer, contact support immediately.
      </div>

      <!-- Transaction details -->
      <div class="detail-card">
        <div class="detail-row">
          <span class="detail-label">Amount Sent</span>
          <span class="detail-value debit">-₦<%= amount.toLocaleString('en-NG', { minimumFractionDigits: 2 }) %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Sent To</span>
          <span class="detail-value"><%= receiverName %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Receiver Account</span>
          <span class="detail-value"><%= receiverAccount %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Balance After</span>
          <span class="detail-value balance">₦<%= balanceAfter.toLocaleString('en-NG', { minimumFractionDigits: 2 }) %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Date & Time</span>
          <span class="detail-value"><%= date %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Status</span>
          <span class="detail-value" style="color: #16a34a;">✓ Successful</span>
        </div>
      </div>

      <!-- Note (if any) -->
      <% if (note) { %>
      <div class="note-box">
        <div class="note-label">📝 Note</div>
        <%= note %>
      </div>
      <% } %>

      <!-- Security notice -->
      <div class="alert-box">
        🔒 <strong>Security tip:</strong> Bank of Saturn will never ask for your PIN, password or OTP via email or phone call. If you did not make this transfer, please contact support immediately.
      </div>
    </div>

    <!-- Footer -->
    <div class="footer">
      <div class="footer-brand">Bank of Saturn</div>
      <div class="footer-text">
        This is an automated alert. Please do not reply to this email.<br/>
        &copy; <%= new Date().getFullYear() %> Bank of Saturn. All rights reserved.
      </div>
      <div class="tx-id">Transaction ID: <%= transactionId %></div>
    </div>

  </div>
</body>
</html>
