<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Debit Alert — Bank of Saturn</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: #f8fafc;
      font-family: 'Segoe UI', Arial, sans-serif;
      color: #1e293b;
    }

    .wrapper {
      max-width: 560px;
      margin: 40px auto;
      background: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(27, 58, 107, 0.1);
      border-top: 4px solid #ef4444;
    }

    /* Header — navy brand */
    .header {
      background: linear-gradient(135deg, #122850 0%, #1b3a6b 50%, #2563eb 100%);
      padding: 32px 40px 26px;
      text-align: center;
    }

    .header-logo {
      font-size: 0.7rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.45);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .header-badge {
      display: inline-block;
      background: rgba(239, 68, 68, 0.18);
      border: 1px solid rgba(239, 68, 68, 0.4);
      color: #fca5a5;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 4px 14px;
      border-radius: 20px;
      margin-bottom: 12px;
    }

    .header-title {
      font-size: 1.4rem;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 4px;
    }

    .header-sub {
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.45);
    }

    /* Amount hero */
    .amount-hero {
      background: #fef2f2;
      padding: 26px 40px;
      text-align: center;
      border-bottom: 2px solid #fecaca;
    }

    .amount-label {
      font-size: 0.68rem;
      font-weight: 700;
      color: #ef4444;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      margin-bottom: 8px;
    }

    .amount-value {
      font-size: 2.8rem;
      font-weight: 800;
      color: #dc2626;
      letter-spacing: -0.02em;
      line-height: 1;
    }

    .amount-sub {
      font-size: 0.78rem;
      color: #f87171;
      margin-top: 7px;
    }

    /* Body */
    .body {
      padding: 30px 40px;
    }

    .greeting {
      font-size: 1rem;
      font-weight: 700;
      color: #1b3a6b;
      margin-bottom: 7px;
    }

    .intro {
      font-size: 0.86rem;
      color: #64748b;
      line-height: 1.7;
      margin-bottom: 26px;
    }

    /* Detail card */
    .card {
      border: 1.5px solid #e2e8f0;
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 20px;
    }

    .card-title {
      background: linear-gradient(135deg, #1b3a6b, #2563eb);
      padding: 10px 18px;
      font-size: 0.64rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.7);
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 13px 18px;
      border-bottom: 1px solid #f8fafc;
    }

    .row:last-child {
      border-bottom: none;
    }

    .row-label {
      font-size: 0.78rem;
      color: #64748b;
      font-weight: 500;
    }

    .row-value {
      font-size: 0.88rem;
      font-weight: 700;
      color: #1e293b;
      text-align: right;
      margin-left: 16px;
    }

    .row-value.debit {
      color: #dc2626;
      font-size: 1rem;
    }

    .row-value.navy {
      color: #1b3a6b;
    }

    .row-value.green {
      color: #16a34a;
    }

    .row-value.mono {
      font-family: 'Courier New', monospace;
      font-size: 0.83rem;
      color: #64748b;
      letter-spacing: 0.05em;
      font-weight: 600;
    }

    /* Note — amber accent */
    .note-box {
      background: #fffbeb;
      border: 1.5px solid #fde68a;
      border-left: 4px solid #d97706;
      border-radius: 10px;
      padding: 13px 16px;
      margin-bottom: 20px;
    }

    .note-label {
      font-size: 0.67rem;
      font-weight: 700;
      color: #d97706;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 5px;
    }

    .note-text {
      font-size: 0.84rem;
      color: #92400e;
      font-style: italic;
      line-height: 1.5;
    }

    /* Security notice — navy accent */
    .alert {
      background: #eff6ff;
      border: 1.5px solid #bfdbfe;
      border-left: 4px solid #2563eb;
      border-radius: 10px;
      padding: 13px 16px;
      margin-bottom: 28px;
      font-size: 0.81rem;
      color: #1b3a6b;
      line-height: 1.65;
    }

    /* Footer */
    .footer {
      background: #f8fafc;
      border-top: 1px solid #e2e8f0;
      padding: 22px 40px;
      text-align: center;
    }

    .footer-brand {
      font-size: 0.84rem;
      font-weight: 700;
      color: #1b3a6b;
      margin-bottom: 6px;
    }

    .footer-text {
      font-size: 0.73rem;
      color: #64748b;
      line-height: 1.75;
    }

    .tx-id {
      font-size: 0.67rem;
      color: #e2e8f0;
      font-family: 'Courier New', monospace;
      margin-top: 10px;
      letter-spacing: 0.04em;
    }
  </style>
</head>

<body>
  <div class="wrapper">

    <div class="header">
      <div class="header-logo">Bank of Saturn</div>
      <div class="header-badge">Debit Alert</div>
      <div class="header-title">You sent money</div>
      <div class="header-sub">Transfer notification</div>
    </div>

    <div class="amount-hero">
      <div class="amount-label">Amount Debited</div>
      <div class="amount-value">-&#8358;<%= amount.toLocaleString('en-NG', { minimumFractionDigits: 2 }) %>
      </div>
      <div class="amount-sub">Transferred to <%= receiverName %>
      </div>
    </div>

    <div class="body">
      <div class="greeting">Hello, <%= fullName %>
      </div>
      <div class="intro">
        Your Bank of Saturn account has been debited for the transfer below.
        If you did not authorise this transaction, please contact our support team immediately.
      </div>

      <div class="card">
        <div class="card-title">Transaction Details</div>
        <div class="row">
          <span class="row-label">Amount Sent</span>
          <span class="row-value debit">-&#8358;<%= amount.toLocaleString('en-NG', { minimumFractionDigits: 2 }) %>
              </span>
        </div>
        <div class="row">
          <span class="row-label">Sent To:</span>
          <span class="row-value">
            <%= receiverName %>
          </span>
        </div>
        <div class="row">
          <span class="row-label">Receiver Account:</span>
          <span class="row-value mono">
            <%= receiverAccount %>
          </span>
        </div>

        <div class="row">
          <span class="row-label">Date & Time:</span>
          <span class="row-value">
            <%= date %>
          </span>
        </div>

        <div class="row">
          <span class="row-label">Ref:</span>
          <span class="row-value">
           <%= transactionId %>
          </span>
        </div>
        <div class="row">
          <span class="row-label">Status:</span>
          <span class="row-value green">&#10003; Successful</span>
        </div>

      </div>

      <% if (note) { %>
        <div class="note-box">
          <div class="note-label">Note</div>
          <div class="note-text">
            <%= note %>
          </div>
        </div>
        <% } %>

          <div class="alert">
            <strong>Security reminder:</strong> Bank of Saturn will never ask for your PIN, password or OTP via email or
            phone.
            If you did not authorise this transfer, contact support immediately.
          </div>
    </div>

    <div class="footer">
      <div class="footer-brand">Bank of Saturn</div>
      <div class="footer-text">
        This is an automated notification. Please do not reply to this email.<br />
        &copy; <%= new Date().getFullYear() %> Bank of Saturn. All rights reserved.
      </div>
    
    </div>

  </div>
</body>

</html>